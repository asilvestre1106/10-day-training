<div class="flex items-center justify-center min-h-[calc(100vh-56px)]">
  <div class="w-full max-w-sm bg-white p-6 rounded-lg shadow-md">
    <h1 class="text-2xl font-bold mb-6 text-center">Log in</h1>

    <%= form_with url: login_path, method: :post, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :email, class: "block font-medium mb-1" %>
        <%= form.email_field :email,
            placeholder: "Enter your email",
            class: "w-full border rounded px-3 py-2" %>
      </div>

      <div>
        <%= form.label :password, class: "block font-medium mb-1" %>
        <%= form.password_field :password,
            placeholder: "Enter your password",
            class: "w-full border rounded px-3 py-2" %>
      </div>

      <%= form.submit "Log in",
          class: "w-full btn-primary" %>
    <% end %>
  </div>
</div>
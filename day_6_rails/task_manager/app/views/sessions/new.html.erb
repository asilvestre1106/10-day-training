<div>
  <div>
    <h1>Log in</h1>
  </div>
  <%= form_with url: login_path, method: :post do |form|%>
    <div>
      <%= form.label :email, "Email"%>
      <%= form.email_field :email, required: true, placeholder: "Enter your email"%>
    </div>
    <div>
      <%= form.label :password, "Password"%>
      <%= form.password_field :password, required: true%>
    </div>

    <div>
      <%= form.submit "Log in", class: "btn-primary" %>
    </div>
  <% end %>
</div>

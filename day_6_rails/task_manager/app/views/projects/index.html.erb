<% content_for :title, "Projects" %>

<div class="max-w-4xl mx-auto px-4 mt-10">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice">
      <%= notice %>
    </p>
  <% end %>

  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="font-bold text-4xl">Projects</h1>
      <p class="text-gray-400 mt-2">
        You have <%= @total_projects %> projects.
      </p>
    </div>

    <div class="flex gap-2">
      <%= link_to "Back to Home", root_path, class: "btn-primary" %>
      <%= link_to "New project",
          new_project_path,
          data: { turbo_frame: "modal" },
          class: "btn-primary" %>
    </div>
  </div>

  <div id="projects" class="space-y-4">
    <% if @projects.any? %>
      <% @projects.each do |project| %>
        <div class="border rounded-lg p-4 flex justify-between items-center hover:shadow-md transition-shadow">
          <%= render project %>

          <div class="flex gap-2">
            <%= link_to "Show", project, class: "btn-secondary" %>
            <%= link_to "Edit",
                edit_project_path(project),
                data: { turbo_frame: "modal" },
                class: "btn-secondary" %>
            <%= button_to "Destroy", project, method: :delete, class: "btn-danger", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10">No projects found.</p>
    <% end %>
  </div>
</div>

<%= turbo_frame_tag "modal" do %>
<% end %>
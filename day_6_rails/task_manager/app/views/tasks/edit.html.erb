<div class="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center z-50">
  <%= link_to "",
      tasks_path,
      data: { turbo_frame: "modal" },
      class: "absolute inset-0 cursor-default" %>

  <div class="relative bg-white rounded-lg shadow-xl p-6 w-full max-w-lg z-10">
    <div class="flex justify-between items-center mb-4">
      <h1 class="text-2xl font-bold">Edit Task</h1>

      <%= link_to "✕",
          tasks_path,
          data: { turbo_frame: "modal" },
          class: "text-xl" %>
    </div>

    <%= render "form", task: @task %>
    <div class="mt-3">
      <%= button_to "Delete Task",
        @task,
        method: :delete,
        data: { turbo_confirm: "Are you sure?" },
        class: "w-full bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-4 rounded-lg transition" %>
    </div>
  </div>
</div>
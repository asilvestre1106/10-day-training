<p style="color: green"><%= notice %></p>

<% content_for :title, "Tasks" %>
<div class="max-w-2x1 mx-auto">
  <h1 class="text-3xl font-bold mb-2">A Simple Task Manager</h1>
  <h3 class="text-gray-400 mb-6">
    You have <%= @total_tasks %> tasks.
  </h3>
  
  <%= link_to "View Projects", projects_path, class: "mb-4 btn-primary"%>
  <%= link_to "New task", new_task_path, class: "mb-4 btn-primary" %>
  <div id="tasks" class="flex justify-around border ">
    <% @tasks.each do |task| %>
      <%= render task %>
    <% end %>
  </div>

  
</div>